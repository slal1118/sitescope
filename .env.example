# Supabase (required — get from https://supabase.com/dashboard/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# OpenAI (optional — enables AI-powered insights)
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Browserless.io (optional — enables full JS/SPA rendering for accurate analysis)
# Get a free trial at https://www.browserless.io
# Without this, Jina Reader is used as a free fallback (partial enrichment only)
BROWSERLESS_API_KEY=

# App (optional)
NEXT_PUBLIC_APP_URL=http://localhost:3000
